{
  "name": "hmstudio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "start": "node run-electron.cjs",
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "npm run build && NODE_ENV=production tsx server.ts",
    "clean": "rm -rf dist dist-electron",
    "lint": "tsc --noEmit",
    "electron:build": "tsc main.ts preload.ts server.ts --outDir dist-electron --target es2022 --module commonjs --skipLibCheck --esModuleInterop && node -e \"const fs = require('fs'); fs.writeFileSync('dist-electron/package.json', '{\\\"type\\\":\\\"commonjs\\\"}')\"",
    "electron:dev": "npm run electron:build && electron .",
    "electron:dist": "npm run build && npm run electron:build && electron-builder build --win && copy /Y dist-packaged\\HMStudio.exe .\\HMStudio.exe"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "lottie-web": "^5.13.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "multer": "^1.4.5-lts.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
